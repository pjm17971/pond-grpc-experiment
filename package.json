{
  "name": "pond-grpc-experiment",
  "private": true,
  "version": "0.0.0",
  "description": "Real-ish three-tier (gRPC → aggregator → React) experiment for pond-ts. See PLAN.md.",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@8.10.2",
  "scripts": {
    "typecheck": "tsc -b",
    "dev": "pnpm -r --parallel --stream dev",
    "dev:web": "pnpm --filter @pond-experiment/web dev",
    "dev:aggregator": "pnpm --filter @pond-experiment/aggregator dev",
    "build:web": "pnpm --filter @pond-experiment/web build",
    "test": "pnpm -r --stream test"
  },
  "devDependencies": {
    "typescript": "~6.0.2"
  }
}
